# Bootstrap Configuration
# Edit this file before running setup.sh or any phase script.
# All phase scripts source this automatically via common.sh.

# ── Git repos ────────────────────────────────────────────────────────────────
# Dotfiles repo is auto-derived from `gh api user` — only set these to override.
# Dotfiles are managed by dot-man (NomadicOS/dot-man).

# Git protocol: "ssh" or "https" (default: https)
# SSH requires a deployed SSH key on GitHub.
# HTTPS uses the gh CLI token (set via gh auth login).
GIT_PROTOCOL="https"

# ── GPG ───────────────────────────────────────────────────────────────────────
# Your GPG key ID (long format). Leave empty to skip explicit trust setting.
GPG_KEY_ID=""

# ── Restic / B2 ───────────────────────────────────────────────────────────────
# These are written to ~/.config/restic/b2.env during phase 06.
# Get keyID and applicationKey from Backblaze App Keys dashboard.
B2_ACCOUNT_ID="your-keyID-here"
B2_ACCOUNT_KEY="your-applicationKey-here"
B2_BUCKET="your-name-restic"

# ── System (Phase 00) ─────────────────────────────────────────────────────────
# Local Unix user. Directly edit this. Needs to match the user you will auth as.
USERNAME="yourname"

# Machine hostname on the network.
NL_HOSTNAME="Nomad"

# System timezone. Use tzdata zone name: America/Chicago, UTC, etc.
TIMEZONE="Europe/Berlin"

# ── User dirs ─────────────────────────────────────────────────────────────────
# Directories to create and back up via restic
BACKUP_DIRS=("$HOME/files" "$HOME/projects")

# ── TPM2 (Phase 10) ───────────────────────────────────────────────────────────
# PCRs to bind the TPM2 LUKS keyslot to. Default 7 (Secure Boot state).
# Use 0,7 for stronger binding (also measures firmware/BIOS code).
# TPM_PCRS="7"
